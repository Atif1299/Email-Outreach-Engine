generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id        Int      @id @default(autoincrement())
  filename  String
  createdAt DateTime @default(now()) @map("created_at")

  leads                 Lead[]
  campaignTargetBatches CampaignTargetBatch[]

  @@map("import_batches")
}

model Lead {
  id                 Int      @id @default(autoincrement())
  importBatchId      Int?     @map("import_batch_id")
  email              String
  dataJson           String   @map("data_json")
  createdAt          DateTime @default(now()) @map("created_at")
  verificationStatus String   @default("pending") @map("verification_status")
  verificationReason String?  @map("verification_reason")
  verifiedAt         DateTime? @map("verified_at")
  verificationMethod String?  @map("verification_method")
  doNotContact       Boolean  @default(false) @map("do_not_contact")
  doNotContactAt     DateTime? @map("do_not_contact_at")
  doNotContactReason String?  @map("do_not_contact_reason")

  importBatch       ImportBatch?              @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  sends             LeadSend[]
  bodyOverrides     LeadBodyOverride[]
  mergePreviews     LeadMergePreview[]
  engagements       LeadCampaignEngagement[]
  smtpAssignments   LeadSmtpAssignment[]

  @@index([email])
  @@index([importBatchId])
  @@index([verificationStatus])
  @@map("leads")
}

model Campaign {
  id             Int      @id @default(autoincrement())
  name           String
  pitchBlock     String   @default("") @map("pitch_block")
  senderInfo     String   @default("") @map("sender_info")
  aiVoice        String   @default("founder") @map("ai_voice")
  outputLanguage String   @default("en") @map("output_language")
  createdAt      DateTime @default(now()) @map("created_at")

  steps         CampaignStep[]
  targetBatches CampaignTargetBatch[]
  sends         LeadSend[]
  bodyOverrides LeadBodyOverride[]
  mergePreviews LeadMergePreview[]
  engagements   LeadCampaignEngagement[]
  smtpAssignments LeadSmtpAssignment[]
  aiBulkJobs      AiBulkJob[]

  @@map("campaigns")
}

model CampaignStep {
  id                      Int     @id @default(autoincrement())
  campaignId              Int     @map("campaign_id")
  stepOrder               Int     @map("step_order")
  delayHoursAfterPrevious Float   @default(0) @map("delay_hours_after_previous")
  subjectTemplate         String  @map("subject_template")
  bodyTemplate            String  @map("body_template")
  useAi                   Boolean @default(false) @map("use_ai")
  bodyFormat              String  @default("plain") @map("body_format")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, stepOrder])
  @@map("campaign_steps")
}

model CampaignTargetBatch {
  campaignId    Int @map("campaign_id")
  importBatchId Int @map("import_batch_id")

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@id([campaignId, importBatchId])
  @@map("campaign_target_batches")
}

model LeadSend {
  id            Int      @id @default(autoincrement())
  leadId        Int      @map("lead_id")
  campaignId    Int      @map("campaign_id")
  stepOrder     Int      @map("step_order")
  subject       String
  bodySnippet   String?  @map("body_snippet")
  smtpMessageId String?  @map("smtp_message_id")
  smtpAccountId Int?     @map("smtp_account_id")
  sentAt        DateTime @default(now()) @map("sent_at")
  openedAt      DateTime? @map("opened_at")
  error         String?

  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  smtpAccount SmtpAccount? @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)

  @@index([leadId, campaignId])
  @@index([smtpAccountId, sentAt])
  @@map("lead_sends")
}

model SmtpAccount {
  id                 Int       @id @default(autoincrement())
  email              String
  password           String    @default("")
  label              String    @default("")
  enabled            Boolean   @default(true)
  sortOrder          Int       @default(0) @map("sort_order")
  exhaustedUntil     DateTime? @map("exhausted_until")
  exhaustReason      String?   @map("exhaust_reason")
  lastUsedAt         DateTime? @map("last_used_at")
  lastInboxCheckedAt DateTime? @map("last_inbox_checked_at")
  lastInboxError     String?   @map("last_inbox_error")
  warmupStartedAt    DateTime? @map("warmup_started_at")
  warmupEnabled      Boolean   @default(false) @map("warmup_enabled")
  createdAt          DateTime  @default(now()) @map("created_at")

  assignments  LeadSmtpAssignment[]
  sends        LeadSend[]
  engagements  LeadCampaignEngagement[]

  @@unique([email])
  @@index([enabled, sortOrder])
  @@map("smtp_accounts")
}

model LeadSmtpAssignment {
  leadId        Int      @map("lead_id")
  campaignId    Int      @map("campaign_id")
  smtpAccountId Int      @map("smtp_account_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  smtpAccount SmtpAccount @relation(fields: [smtpAccountId], references: [id], onDelete: Cascade)

  @@id([leadId, campaignId])
  @@map("lead_smtp_assignments")
}

model LeadCampaignEngagement {
  leadId          Int       @map("lead_id")
  campaignId      Int       @map("campaign_id")
  status          String    @default("active")
  repliedAt       DateTime? @map("replied_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  replySubject    String?   @map("reply_subject")
  replySnippet    String?   @map("reply_snippet")
  detectedVia     String?   @map("detected_via")
  inboxAccountId  Int?      @map("inbox_account_id")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  inboxAccount SmtpAccount? @relation(fields: [inboxAccountId], references: [id], onDelete: SetNull)

  @@id([leadId, campaignId])
  @@index([campaignId, status])
  @@map("lead_campaign_engagements")
}

model InboxSyncState {
  id            Int       @id @default(1)
  lastCheckedAt DateTime? @map("last_checked_at")
  lastError     String?   @map("last_error")
  updatedAt     DateTime  @default(now()) @map("updated_at")

  @@map("inbox_sync_state")
}

model LeadBodyOverride {
  leadId     Int      @map("lead_id")
  campaignId Int      @map("campaign_id")
  stepOrder  Int      @map("step_order")
  body       String
  subject    String?
  updatedAt  DateTime @default(now()) @map("updated_at")

  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([leadId, campaignId, stepOrder])
  @@map("lead_body_overrides")
}

model LeadMergePreview {
  leadId      Int      @map("lead_id")
  campaignId  Int      @map("campaign_id")
  stepOrder   Int      @map("step_order")
  previewText String   @map("preview_text")
  updatedAt   DateTime @default(now()) @map("updated_at")

  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([leadId, campaignId, stepOrder])
  @@map("lead_merge_previews")
}

model Settings {
  id                   Int     @id @default(1)
  smtpHost             String  @default("smtp.gmail.com") @map("smtp_host")
  smtpPort             Int     @default(465) @map("smtp_port")
  smtpSecure           Boolean @default(true) @map("smtp_secure")
  smtpUser             String  @default("") @map("smtp_user")
  smtpPassword         String  @default("") @map("smtp_password")
  smtpFromName         String  @default("") @map("smtp_from_name")
  smtpFromEmail        String  @default("") @map("smtp_from_email")
  sendDelayMinMs       Int     @default(60000) @map("send_delay_min_ms")
  sendDelayMaxMs       Int     @default(240000) @map("send_delay_max_ms")
  dailyCap             Int     @default(300) @map("daily_cap")
  dailyStep1Cap        Int     @default(0) @map("daily_step1_cap")
  dailyFollowUpCap     Int     @default(0) @map("daily_follow_up_cap")
  hourlyCap            Int     @default(25) @map("hourly_cap")
  sendTimezone         String  @default("Asia/Karachi") @map("send_timezone")
  sendStartHour        Int     @default(12) @map("send_start_hour")
  openaiKey            String  @default("") @map("openai_key")
  openaiModel          String  @default("gpt-4o-mini") @map("openai_model")
  aiProvider           String  @default("openai") @map("ai_provider")
  geminiApiKey         String  @default("") @map("gemini_api_key")
  geminiModel          String  @default("gemini-2.5-flash") @map("gemini_model")
  verificationProvider String  @default("none") @map("verification_provider")
  verificationApiKey   String  @default("") @map("verification_api_key")

  @@map("settings")
}

model QueueState {
  id                   Int      @id @default(1)
  running              Boolean  @default(false)
  paused               Boolean  @default(false)
  lastError            String?  @map("last_error")
  processedInSession   Int      @default(0) @map("processed_in_session")
  failedInSession      Int      @default(0) @map("failed_in_session")
  sessionStartedAt     DateTime? @map("session_started_at")
  consecutiveFailures  Int      @default(0) @map("consecutive_failures")
  activeCampaignId     Int?     @map("active_campaign_id")
  activeLeadIdsJson    String   @default("[]") @map("active_lead_ids_json")
  skippedLeadIdsJson   String   @default("[]") @map("skipped_lead_ids_json")
  activeCampaignsJson  String   @default("[]") @map("active_campaigns_json")
  lastServedCampaignId Int?     @map("last_served_campaign_id")
  processingLockUntil  DateTime? @map("processing_lock_until")
  nextSendAllowedAt    DateTime? @map("next_send_allowed_at")
  updatedAt            DateTime @default(now()) @map("updated_at")

  @@map("queue_state")
}

model AiBulkJob {
  id                   Int       @id @default(autoincrement())
  campaignId           Int       @map("campaign_id")
  stepOrder            Int       @map("step_order")
  status               String    @default("running")
  regenerateAll        Boolean   @default(false) @map("regenerate_all")
  total                Int       @default(0)
  processed            Int       @default(0)
  generated            Int       @default(0)
  failed               Int       @default(0)
  skipped              Int       @default(0)
  pendingLeadIdsJson   String    @default("[]") @map("pending_lead_ids_json")
  failedLeadIdsJson    String    @default("[]") @map("failed_lead_ids_json")
  batchPauseUntil      DateTime? @map("batch_pause_until")
  batchWindowStartedAt DateTime? @map("batch_window_started_at")
  leadsInWindow        Int       @default(0) @map("leads_in_window")
  processingLockUntil  DateTime? @map("processing_lock_until")
  lastError            String?   @map("last_error")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")
  completedAt          DateTime? @map("completed_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, stepOrder, status])
  @@map("ai_bulk_jobs")
}
