# Local development overrides (not committed — copy from .env.example)
# DATABASE_URL — use Neon POOLED connection string in production (hostname contains -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST-pooler/neondb?sslmode=require"

# Required for background queue on Vercel (cron-job.org or Vercel Pro cron)
CRON_SECRET="your-random-secret-here"

# Set to "true" on Vercel so the queue runs via cron, not the browser tab
NEXT_PUBLIC_USE_CRON_WORKER="false"

# Optional: only needed if you prefer env-based secrets instead of the dashboard
# OPENAI_API_KEY=""
# SMTP_PASSWORD=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
