{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./web/*"
      ]
    }
  },
  "include": [
    "web/next-env.d.ts",
    "web/**/*.ts",
    "web/**/*.tsx",
    "web/.next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "web/node_modules"
  ]
}